{
  "name": "tree-sitter-twig",
  "version": "0.4.0",
  "description": "Twig grammar for tree-sitter",
  "main": "bindings/node",
  "scripts": {
    "install": ":",
    "clean": "rm -rf ./tree-sitter-twig.wasm ./build ./node_modules ./prebuilds",
    "build": "tree-sitter generate --abi=14 && rm -f ./tree-sitter-twig.wasm",
    "build-wasm": "bun run build && tree-sitter build -w",
    "test": "tree-sitter test"
  },
  "license": "Mozilla Public License 2.0",
  "dependencies": {
    "node-addon-api": "^8.2.2"
  },
  "devDependencies": {
    "tree-sitter-cli": "0.25.3"
  },
  "files": [
    "README.md",
    "LICENSE",
    "tree-sitter-twig.wasm"
  ]
}
