{
  "name": "twiggy-root",
  "version": "26.4.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moetelo/twiggy.git"
  },
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/node": "^20.12.7",
      "esbuild": "^0.28.0",
      "typescript": "^6.0.3"
    }
  },
  "trustedDependencies": [
    "esbuild",
    "tree-sitter-cli"
  ],
  "scripts": {
    "build": "bun run --cwd ./packages/vscode build",
    "dev": "bun run --cwd ./packages/vscode dev",
    "build-grammar-wasm": "bun run --cwd ./packages/tree-sitter-twig build-wasm",
    "test": "bun run --cwd ./packages/language-server test",
    "typecheck": "bun run --cwd ./packages/language-server typecheck && bun run --cwd ./packages/vscode typecheck",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist && bun run --cwd ./packages/tree-sitter-twig clean"
  },
  "author": "Mikhail Gunin <gunka462@gmail.com>",
  "license": "Mozilla Public License 2.0"
}
